<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent">

	<ImageView android:layout_width="match_parent" android:layout_height="800px" android:id="@+id/imageView42"
			   android:scaleType="fitXY" android:src="#ffffffff"/>
	<RelativeLayout android:layout_width="300px" android:layout_height="300px" android:id="@+id/relativeLayout2"
					android:layout_centerHorizontal="true" android:layout_marginTop="80px">
		<ImageView android:layout_width="fill_parent" android:layout_height="fill_parent" android:id="@+id/imageView43"
				   android:src="@drawable/preset_logo" android:visibility="visible"/>
	</RelativeLayout>
	<VideoView android:id="@+id/videoView_logo"
			   android:layout_alignParentTop="true"
			   android:layout_alignParentBottom="true"
			   android:layout_alignParentLeft="true"
			   android:layout_alignParentRight="true"
			   android:layout_width="fill_parent"
			   android:layout_height="fill_parent" android:visibility="gone">
	</VideoView>
	<RelativeLayout
			android:layout_width="266px"
			android:layout_height="60px" android:layout_centerHorizontal="true" android:id="@+id/journal_layout"
			android:layout_marginTop="575px">
		<ImageView
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:id="@+id/bk1" android:background="@drawable/preset_round_green_green"
				android:alpha="0.7"/>
		<RelativeLayout
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:layout_centerInParent="true">
			<ImageView
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:id="@+id/img_journal" android:layout_marginTop="10px" android:layout_marginBottom="10px"
					android:scaleType="centerInside" android:src="@drawable/bk_journal"/>
			<TextView
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:text="访客"
					android:id="@+id/txt_skip" android:layout_toRightOf="@+id/img_journal" android:textColor="#FFFFFF"
					android:textSize="24px" android:gravity="center_vertical" android:layout_marginLeft="10px"/>
		</RelativeLayout>
		<ImageButton
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:id="@+id/btn_skip" android:background="@drawable/preset_btn_round_transparent_transparent"/>
	</RelativeLayout>
	<RelativeLayout
			android:layout_width="266px"
			android:layout_height="60px" android:layout_centerHorizontal="true" android:id="@+id/login_layout"
			android:layout_marginTop="30px" android:layout_below="@+id/journal_layout"
			>
		<ImageView
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:id="@+id/bk2" android:background="@drawable/preset_round_green_green"
				android:alpha="0.7"/>
		<RelativeLayout
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:layout_marginLeft="150px" android:layout_centerInParent="true">
			<ImageView
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:id="@+id/img_key" android:layout_marginTop="10px" android:layout_marginBottom="10px"
					android:scaleType="centerInside" android:src="@drawable/bk_key"/>
			<TextView
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:text="登录"
					android:id="@+id/txt_login" android:layout_toRightOf="@+id/img_key" android:textColor="#FFFFFF"
					android:textSize="24px" android:gravity="center_vertical" android:layout_marginLeft="20px"/>
		</RelativeLayout>
		<ImageButton
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:id="@+id/btn_login" android:background="@drawable/preset_btn_round_transparent_transparent"/>
	</RelativeLayout>
</RelativeLayout>