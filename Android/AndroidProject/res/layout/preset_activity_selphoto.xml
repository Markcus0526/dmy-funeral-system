<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="fill_parent"
				android:layout_height="fill_parent" android:background="#60000000" android:id="@+id/parent_layout">

	<Button
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Back"
			android:id="@+id/btn_back" android:visibility="gone"/>
	<RelativeLayout
			android:layout_width="300px"
			android:layout_height="wrap_content" android:id="@+id/back_layout" android:layout_centerInParent="true"
			>
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="70px"
				android:id="@+id/title_layout">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/txt_title" android:textColor="#FFFFFF" android:textSize="26px"
					android:gravity="center" android:text="选择头像" android:background="@color/TITLE_BACKCOLOR"/>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="70px" android:id="@+id/takephoto_layout" android:layout_below="@+id/title_layout"
				android:background="#FFFFFF">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:text="拍照"
					android:id="@+id/txt_takephoto" android:textSize="24px" android:textColor="#404040"
					android:gravity="center"
					/>
			<Button
									android:layout_width="fill_parent"
									android:layout_height="fill_parent"
									android:id="@+id/btn_take_photo" android:background="@drawable/preset_btn_rect_transparent_transparent"
									android:textColor="#606060" android:textSize="22px"/>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="70px" android:id="@+id/gallery_layout" android:layout_below="@+id/takephoto_layout"
				android:background="#FFFFFF">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:text="相册"
					android:id="@+id/txt_selphoto" android:textSize="24px" android:textColor="#404040"
					android:gravity="center"
					/>
			<Button
									android:layout_width="fill_parent"
									android:layout_height="fill_parent"
									android:id="@+id/btn_sel_image" android:background="@drawable/preset_btn_rect_transparent_transparent"
									android:textColor="#606060" android:textSize="22px"/>
			<RelativeLayout
					android:layout_width="fill_parent"
					android:layout_height="1px" android:background="#a7a7a7" android:id="@+id/sep_layout1">
			</RelativeLayout>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="70px" android:id="@+id/cancelphoto" android:layout_below="@+id/gallery_layout"
				android:background="#FFFFFF">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:text="取消"
					android:id="@+id/txt_cancel" android:textSize="24px" android:textColor="#404040"
					android:gravity="center"
					/>
			<Button
									android:layout_width="fill_parent"
									android:layout_height="fill_parent"
									android:id="@+id/btn_cancel"
									android:textColor="#606060"
									android:background="@drawable/preset_btn_rect_transparent_transparent" android:textSize="22px"/>
			<RelativeLayout android:layout_width="fill_parent" android:layout_height="1px" android:background="#a7a7a7"
							android:id="@+id/sel_layout2"/>
		</RelativeLayout>
	</RelativeLayout>
	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="fill_parent" android:id="@+id/crop_layout" android:background="#FF000000"
			android:visibility="gone">
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="fill_parent"
				android:id="@+id/image_layout" android:layout_above="@+id/oper_layout"
				>
			<ImageView
					android:layout_width="fill_parent"
					android:layout_height="fill_parent"
					android:id="@+id/img_sel" android:scaleType="matrix"/>
			<view android:layout_width="match_parent"
				  android:layout_height="match_parent"
				  class="com.damytech.preset_controls.PhotoClipView" android:id="@+id/clipview"/>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="80px" android:layout_alignParentBottom="true" android:id="@+id/oper_layout">
			<RelativeLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" android:layout_centerInParent="true">
				<Button
						android:layout_width="200px"
						android:layout_height="50px"
						android:text="确定"
						android:id="@+id/btn_confirm" android:background="@drawable/preset_btn_round_green_green"
						android:textSize="24px" android:textColor="#FFFFFF"/>
			</RelativeLayout>
		</RelativeLayout>
	</RelativeLayout>
</RelativeLayout>