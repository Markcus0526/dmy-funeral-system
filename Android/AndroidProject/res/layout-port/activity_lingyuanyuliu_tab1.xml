<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:background="@color/NORMAL_BACKCOLOR">

	<ScrollView
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:id="@+id/main_scroll">
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="fill_parent" android:id="@+id/scroll_content" android:paddingBottom="30px">
			<RelativeLayout
					android:layout_width="fill_parent"
					android:layout_height="wrap_content" android:id="@+id/info_layout">
				<TextView
						android:layout_width="150px"
						android:layout_height="50px"
						android:text="购买人姓名："
						android:id="@+id/lbl_username" android:layout_marginTop="70px" android:layout_marginLeft="30px"
						android:textColor="#303030" android:textSize="22px" android:gravity="center_vertical|right"/>
				<EditText
						android:layout_width="250px"
						android:layout_height="wrap_content"
						android:id="@+id/edt_username" android:layout_alignTop="@+id/lbl_username"
						android:layout_toRightOf="@+id/lbl_username" android:layout_marginLeft="10px"
						android:layout_alignBottom="@+id/lbl_username" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical"
						android:background="@drawable/preset_round_transparent_gray" android:singleLine="true"
						android:paddingLeft="10px" android:paddingRight="10px" android:inputType="text"/>
				<TextView
						android:layout_width="150px"
						android:layout_height="50px"
						android:text="手机号码："
						android:id="@+id/lbl_userphone" android:layout_marginTop="20px" android:layout_below="@+id/lbl_username"
						android:layout_alignLeft="@+id/lbl_username" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical|right"/>
				<EditText
						android:layout_width="250px"
						android:layout_height="wrap_content"
						android:id="@+id/edt_userphone" android:layout_alignTop="@+id/lbl_userphone"
						android:layout_toRightOf="@+id/lbl_userphone" android:layout_marginLeft="10px"
						android:layout_alignBottom="@+id/lbl_userphone" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical"
						android:background="@drawable/preset_round_transparent_gray" android:singleLine="true"
						android:paddingLeft="10px" android:paddingRight="10px" android:inputType="phone"
						android:maxLength="11"/>
				<TextView
						android:layout_width="150px"
						android:layout_height="50px"
						android:text="末者："
						android:id="@+id/lbl_death1" android:layout_marginTop="50px" android:layout_below="@+id/lbl_userphone"
						android:layout_alignLeft="@+id/lbl_userphone" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical|right"/>
				<EditText
						android:layout_width="250px"
						android:layout_height="wrap_content"
						android:id="@+id/edt_death1" android:layout_toRightOf="@+id/lbl_death1"
						android:layout_alignTop="@+id/lbl_death1" android:layout_marginLeft="10px"
						android:layout_alignBottom="@+id/lbl_death1" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical"
						android:background="@drawable/preset_round_transparent_gray" android:singleLine="true"
						android:paddingLeft="10px" android:paddingRight="10px" android:inputType="text"/>
				<TextView
						android:layout_width="150px"
						android:layout_height="50px"
						android:text="抚慰人："
						android:id="@+id/lbl_mgr1" android:layout_marginTop="20px" android:layout_below="@+id/lbl_death1"
						android:layout_alignLeft="@+id/lbl_death1" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical|right"/>
				<EditText
						android:layout_width="250px"
						android:layout_height="wrap_content"
						android:id="@+id/edt_mgr1" android:layout_alignTop="@+id/lbl_mgr1"
						android:layout_toRightOf="@+id/lbl_mgr1" android:layout_marginLeft="10px"
						android:layout_alignBottom="@+id/lbl_mgr1" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical"
						android:background="@drawable/preset_round_transparent_gray" android:singleLine="true"
						android:paddingLeft="10px" android:paddingRight="10px" android:inputType="text"/>
				<TextView
						android:layout_width="150px"
						android:layout_height="50px"
						android:text="末者："
						android:id="@+id/lbl_death2" android:layout_marginTop="50px" android:layout_below="@+id/lbl_mgr1"
						android:layout_alignLeft="@+id/lbl_mgr1" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical|right"/>
				<EditText
						android:layout_width="250px"
						android:layout_height="wrap_content"
						android:id="@+id/edt_death2" android:layout_alignTop="@+id/lbl_death2"
						android:layout_toRightOf="@+id/lbl_death2" android:layout_marginLeft="10px"
						android:layout_alignBottom="@+id/lbl_death2" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical"
						android:background="@drawable/preset_round_transparent_gray" android:singleLine="true"
						android:paddingLeft="10px" android:paddingRight="10px" android:inputType="text"/>
				<TextView
						android:layout_width="150px"
						android:layout_height="50px"
						android:text="抚慰人："
						android:id="@+id/lbl_mgr2" android:layout_marginTop="20px" android:layout_below="@+id/lbl_death2"
						android:layout_alignLeft="@+id/lbl_death2" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical|right"/>
				<EditText
						android:layout_width="250px"
						android:layout_height="wrap_content"
						android:id="@+id/edt_mgr2" android:layout_toRightOf="@+id/lbl_mgr2"
						android:layout_alignTop="@+id/lbl_mgr2" android:layout_marginLeft="10px"
						android:layout_alignBottom="@+id/lbl_mgr2" android:textColor="#303030" android:textSize="22px"
						android:gravity="center_vertical"
						android:background="@drawable/preset_round_transparent_gray" android:singleLine="true"
						android:paddingLeft="10px" android:paddingRight="10px" android:inputType="text"/>
			</RelativeLayout>
			<RelativeLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" android:id="@+id/operation_layout"
					android:layout_alignParentBottom="false"
					android:layout_centerHorizontal="true" android:layout_below="@+id/info_layout"
					android:layout_marginTop="50px">
				<Button android:layout_width="160px" android:layout_height="50px" android:text="取消" android:id="@+id/btn_cancel"
						android:background="@drawable/preset_btn_round_white_gray" android:textSize="24px"
						android:textColor="#404040"/>
				<Button android:layout_width="160px" android:layout_height="54px" android:text="下一步" android:id="@+id/btn_next"
						android:layout_toRightOf="@+id/btn_cancel" android:layout_marginLeft="40px"
						android:background="@drawable/preset_btn_round_green_green" android:textSize="24px"
						android:textColor="#FFFFFF"/>
			</RelativeLayout>
		</RelativeLayout>
	</ScrollView>
</RelativeLayout>