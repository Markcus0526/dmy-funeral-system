<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:background="@color/NORMAL_BACKCOLOR">
	<RelativeLayout android:layout_width="fill_parent" android:layout_height="@dimen/TITLE_HEIGHT"
					android:background="@color/TITLE_BACKCOLOR" android:id="@+id/title_layout">
		<TextView android:layout_width="match_parent" android:layout_height="match_parent"
				  android:text="代祭拜详情" android:id="@+id/txt_title" android:textColor="@color/TITLE_FORECOLOR"
				  android:textSize="@dimen/TITLE_FONTSIZE" android:gravity="center"/>
		<ImageButton android:layout_width="@dimen/BACKBUTTON_WIDTH" android:layout_height="match_parent"
					 android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
					 android:src="@drawable/preset_btn_back" android:padding="10px"/>
		<ImageButton
				android:layout_width="70px"
				android:layout_height="match_parent"
				android:id="@+id/btn_user" android:layout_alignParentRight="true" android:background="@null"
				android:scaleType="centerInside" android:src="@drawable/preset_btn_user" android:padding="10px"
				android:visibility="invisible"/>
	</RelativeLayout>
	<RelativeLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
					android:id="@+id/content_layout" android:layout_below="@+id/title_layout">
		<ScrollView
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:id="@+id/main_scroll">
			<RelativeLayout
					android:layout_width="fill_parent"
					android:layout_height="fill_parent" android:id="@+id/scroll_content_layout"
					android:paddingBottom="30px">
				<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="执行日期："
						android:id="@+id/lbl_date" android:textSize="24px" android:textColor="#303030"
						android:layout_marginLeft="20px" android:layout_marginTop="50px"/>
				<TextView
						android:layout_width="440px"
						android:layout_height="wrap_content"
						android:id="@+id/txt_date" android:textSize="24px" android:textColor="#303030"
						android:layout_toRightOf="@+id/lbl_date" android:layout_alignTop="@+id/lbl_date"
						android:layout_marginRight="20px"/>
				<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="服务人员："
						android:id="@+id/lbl_service" android:textSize="24px" android:textColor="#303030"
						android:layout_marginLeft="20px" android:layout_below="@+id/txt_date"
						android:layout_marginTop="30px"/>
				<TextView
						android:layout_width="440px"
						android:layout_height="wrap_content"
						android:id="@+id/txt_service" android:textSize="24px" android:textColor="#303030"
						android:layout_alignTop="@+id/lbl_service" android:layout_toRightOf="@+id/lbl_service"
						android:layout_marginRight="20px"/>
				<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="详细照片："
						android:id="@+id/lbl_images" android:textColor="#303030" android:textSize="24px"
						android:layout_marginLeft="20px" android:layout_marginTop="30px"
						android:layout_below="@+id/txt_service" android:layout_marginRight="20px"/>
				<LinearLayout
						android:orientation="vertical"
						android:layout_width="fill_parent"
						android:layout_height="fill_parent" android:id="@+id/images_layout"
						android:layout_below="@+id/lbl_images" android:layout_alignLeft="@+id/lbl_images"
						android:layout_alignRight="@+id/lbl_images" android:layout_marginTop="10px">
				</LinearLayout>
			</RelativeLayout>
		</ScrollView>
	</RelativeLayout>
</RelativeLayout>