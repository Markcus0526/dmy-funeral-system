<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:id="@+id/parent_layout"
				android:background="@color/NORMAL_BACKCOLOR">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="fill_parent" android:id="@+id/data_layout"
			android:layout_above="@+id/operation_layout" android:layout_marginBottom="20px"
			>
		<LinearLayout
				android:orientation="horizontal"
				android:layout_width="fill_parent"
				android:layout_height="60px" android:id="@+id/navigation_layout">
			<RelativeLayout
					android:layout_width="0dp"
					android:layout_height="fill_parent" android:layout_weight="9" android:id="@+id/rlXianHua"
					android:visibility="visible">
				<ImageView
						android:layout_width="40px"
						android:layout_height="match_parent"
						android:id="@+id/img_flower" android:scaleType="centerInside"
						android:src="@drawable/bk_radio_sel"/>
				<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:text="鲜花"
						android:id="@+id/txt_flowers" android:textColor="#303030" android:textSize="20px"
						android:gravity="center_vertical" android:layout_toRightOf="@+id/img_flower"/>
				<ImageButton
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:id="@+id/btn_flowers" android:background="@null"/>
			</RelativeLayout>
			<RelativeLayout
					android:layout_width="0dp"
					android:layout_height="fill_parent" android:layout_weight="12" android:id="@+id/rlSuiZangPin">
				<ImageView
						android:layout_width="40px"
						android:layout_height="match_parent"
						android:id="@+id/img_burial" android:scaleType="centerInside"
						android:src="@drawable/bk_radio_normal"/>
				<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:text="随葬品"
						android:id="@+id/txt_burial" android:textColor="#303030" android:textSize="20px"
						android:gravity="center_vertical" android:layout_toRightOf="@+id/img_burial"/>
				<ImageButton
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:id="@+id/btn_burials" android:background="@null"/>
			</RelativeLayout>
			<RelativeLayout
					android:layout_width="0dp"
					android:layout_height="fill_parent" android:layout_weight="14" android:id="@+id/rlGongFan">
				<ImageView
						android:layout_width="40px"
						android:layout_height="match_parent"
						android:id="@+id/img_meal" android:scaleType="centerInside"
						android:src="@drawable/bk_radio_normal"/>
				<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:text="供饭/水果"
						android:id="@+id/txt_meal" android:textColor="#303030" android:textSize="20px"
						android:gravity="center_vertical" android:layout_toRightOf="@+id/img_meal"/>
				<ImageButton
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:id="@+id/btn_meal" android:background="@null"/>
			</RelativeLayout>
			<RelativeLayout
					android:layout_width="0dp"
					android:layout_height="fill_parent" android:layout_weight="10" android:id="@+id/rlQiTa">
				<ImageView
						android:layout_width="40px"
						android:layout_height="match_parent"
						android:id="@+id/img_others" android:scaleType="centerInside"
						android:src="@drawable/bk_radio_normal"/>
				<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:text="其他"
						android:id="@+id/txt_others" android:textColor="#303030" android:textSize="20px"
						android:gravity="center_vertical" android:layout_toRightOf="@+id/img_others"/>
				<ImageButton
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:id="@+id/btn_others" android:background="@null"/>
			</RelativeLayout>
		</LinearLayout>
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="fill_parent"
				android:id="@+id/list_container_layout" android:layout_below="@+id/navigation_layout">
			<ListView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/list_flowers" android:cacheColorHint="#E0E0E0"/>
			<ListView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/list_burials" android:cacheColorHint="#E0E0E0" android:visibility="invisible"/>
			<ListView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/list_meal" android:cacheColorHint="#E0E0E0" android:visibility="invisible"/>
			<ListView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/list_others" android:cacheColorHint="#E0E0E0" android:visibility="invisible"/>
		</RelativeLayout>
	</RelativeLayout>
	<RelativeLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
					android:id="@+id/operation_layout" android:layout_centerHorizontal="true"
					android:layout_alignParentBottom="true" android:layout_marginBottom="30px">
		<Button android:layout_width="160px" android:layout_height="50px" android:text="上一步" android:id="@+id/btn_prev"
				android:background="@drawable/preset_btn_round_green_green" android:textSize="24px"
				android:textColor="#FFFFFF"/>
		<Button android:layout_width="160px" android:layout_height="54px" android:text="确认" android:id="@+id/btn_next"
				android:layout_toRightOf="@+id/btn_prev" android:layout_marginLeft="40px"
				android:background="@drawable/preset_btn_round_green_green" android:textSize="24px"
				android:textColor="#FFFFFF"/>
	</RelativeLayout>
</RelativeLayout>