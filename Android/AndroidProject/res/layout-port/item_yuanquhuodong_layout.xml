<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR" android:padding="12px"
			android:id="@+id/content_layout">
		<RelativeLayout
				android:layout_width="fill_parent"
				android:layout_height="wrap_content" android:id="@+id/main_info_layout"
				android:layout_toLeftOf="@+id/img_right">
			<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="New Text"
					android:id="@+id/txt_title" android:textSize="24px" android:textColor="#303030"
					android:layout_marginLeft="10px"
					android:layout_alignParentLeft="true" android:paddingRight="14px" android:singleLine="true"
					android:ellipsize="end"/>
			<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="New Text"
					android:id="@+id/txt_time" android:textSize="20px" android:textColor="#505050"
					android:layout_alignLeft="@+id/txt_title" android:layout_below="@+id/txt_title"
					android:layout_marginTop="10px"/>
			<ImageView
					android:layout_width="20px"
					android:layout_height="20px"
					android:id="@+id/img_new" android:background="@drawable/preset_circle_red"
					android:layout_alignRight="@+id/txt_title" android:layout_alignTop="@+id/txt_title"/>
		</RelativeLayout>
		<ImageView
				android:layout_width="50px"
				android:layout_height="40px"
				android:id="@+id/img_right" android:layout_alignParentRight="true" android:scaleType="centerInside"
				android:src="@drawable/bk_right_arrow" android:layout_centerVertical="true"/>
	</RelativeLayout>
	<ImageButton
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:id="@+id/btn_item" android:layout_alignTop="@+id/content_layout"
			android:layout_alignLeft="@+id/content_layout" android:layout_alignBottom="@+id/content_layout"
			android:layout_alignRight="@+id/content_layout"
			android:background="@drawable/preset_btn_rect_transparent_transparent"/>
</RelativeLayout>