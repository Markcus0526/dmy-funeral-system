<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:background="@color/NORMAL_BACKCOLOR"
				android:id="@+id/parent_layout">

	<view android:layout_width="match_parent"
		  android:layout_height="match_parent"
		  class="com.damytech.preset_controls.CusImgMapView" android:id="@+id/cus_img_view"
		  android:layout_above="@+id/operation_layout"/>
	<RelativeLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
					android:id="@+id/operation_layout"
					android:layout_alignParentBottom="true" android:layout_marginBottom="30px"
					android:layout_centerHorizontal="true" android:visibility="gone">
		<Button android:layout_width="160px" android:layout_height="50px" android:text="上一步" android:id="@+id/btn_prev"
				android:background="@drawable/preset_btn_round_green_green" android:textSize="24px"
				android:textColor="#FFFFFF"/>
	</RelativeLayout>
</RelativeLayout>