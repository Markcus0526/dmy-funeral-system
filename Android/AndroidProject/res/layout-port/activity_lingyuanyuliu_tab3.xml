<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:id="@+id/parent_layout"
				android:background="@color/NORMAL_BACKCOLOR">

	<LinearLayout
			android:orientation="horizontal"
			android:layout_width="fill_parent"
			android:layout_height="130px" android:id="@+id/legend_layout">
		<RelativeLayout
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="1">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="50px"
					android:text="已购买"
					android:id="@+id/lbl_yigoumai" android:textColor="#303030"
					android:textSize="22px" android:gravity="bottom|center_horizontal" android:paddingBottom="10px"/>
			<ImageView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/img_yigoumai" android:scaleType="centerInside"
					android:layout_below="@+id/lbl_yigoumai" android:src="@drawable/bk_tomb_yigoumai"/>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="1">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="50px"
					android:text="已付定"
					android:id="@+id/lbl_yifuding" android:textColor="#303030"
					android:textSize="22px" android:gravity="bottom|center_horizontal" android:paddingBottom="10px"/>
			<ImageView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/img_yifuding" android:scaleType="centerInside"
					android:layout_below="@+id/lbl_yifuding" android:src="@drawable/bk_tomb_yifuding"/>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="1">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="50px"
					android:text="已保留"
					android:id="@+id/lbl_yibaoliu" android:textColor="#303030"
					android:textSize="22px" android:gravity="bottom|center_horizontal" android:paddingBottom="10px"/>
			<ImageView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/img_yibaoliu" android:scaleType="centerInside"
					android:layout_below="@+id/lbl_yibaoliu" android:src="@drawable/bk_tomb_yibaoliu"/>
		</RelativeLayout>
		<RelativeLayout
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="1">
			<TextView
					android:layout_width="match_parent"
					android:layout_height="50px"
					android:text="空位"
					android:id="@+id/lbl_kongwei" android:textColor="#303030"
					android:textSize="22px" android:gravity="bottom|center_horizontal" android:paddingBottom="10px"/>
			<ImageView
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:id="@+id/img_kongwei" android:scaleType="centerInside"
					android:layout_below="@+id/lbl_kongwei" android:src="@drawable/bk_tomb_kong"/>
		</RelativeLayout>
	</LinearLayout>
	<view android:layout_width="match_parent"
		  android:layout_height="match_parent"
		  class="com.damytech.preset_controls.TDScrollView" android:id="@+id/tomb_scrollview"
		  android:layout_below="@+id/legend_layout" android:layout_marginLeft="10px" android:layout_marginRight="10px"
		  android:layout_marginBottom="20px" android:layout_marginTop="30px"
		  android:layout_above="@+id/operation_layout" android:background="#E0E0E0"/>
	<RelativeLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content" android:layout_alignParentBottom="true"
			android:layout_centerHorizontal="true" android:layout_marginBottom="20px"
			android:id="@+id/operation_layout">
		<Button android:layout_width="160px" android:layout_height="50px" android:text="上一步" android:id="@+id/btn_prev"
				android:background="@drawable/preset_btn_round_green_green" android:textSize="24px"
				android:textColor="#FFFFFF"/>
	</RelativeLayout>
</RelativeLayout>