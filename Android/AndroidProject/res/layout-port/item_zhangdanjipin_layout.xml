<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR"
				android:paddingBottom="10px">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR"
			android:id="@+id/content_layout"
			android:layout_marginLeft="50px" android:layout_marginRight="10px"
			android:layout_marginTop="10px">
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:id="@+id/txt_name" android:textColor="#303030" android:textSize="22px"
				/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:id="@+id/txt_date" android:textSize="22px" android:textColor="#303030"
				android:layout_alignParentLeft="false" android:paddingRight="14px" android:singleLine="true"
				android:ellipsize="end" android:layout_toRightOf="@+id/txt_name" android:layout_marginLeft="10px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:id="@+id/txt_amount" android:textColor="#303030" android:textSize="22px"
				android:layout_toRightOf="@+id/txt_date"/>
	</RelativeLayout>
	<ImageView
			android:layout_width="match_parent"
			android:layout_height="1px"
			android:id="@+id/img_sep" android:layout_below="@+id/content_layout"
			android:layout_alignRight="@+id/content_layout" android:layout_marginLeft="40px"
			android:background="#505050"/>
</RelativeLayout>