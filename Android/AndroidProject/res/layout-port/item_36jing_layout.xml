<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:background="#FFFFFF" android:id="@+id/parent_layout">

	<RelativeLayout android:layout_width="fill_parent" android:layout_height="wrap_content"
					android:id="@+id/content_layout" android:paddingBottom="10px">
		<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="New Text"
				  android:id="@+id/txt_title" android:gravity="center_vertical" android:textColor="#303030"
				  android:textSize="22px" android:paddingLeft="20px" android:layout_toRightOf="@+id/img_contents"
				  android:layout_alignTop="@+id/img_contents" android:paddingRight="20px" android:singleLine="false"/>
		<ImageView android:layout_width="100px" android:layout_height="100px" android:id="@+id/img_contents"
				   android:layout_marginTop="10px"
				   android:background="@drawable/preset_rect_transparent_gray"
				   android:layout_marginLeft="20px"
				   android:scaleType="centerInside"/>
	</RelativeLayout>
	<ImageButton
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:id="@+id/btn_item" android:layout_alignTop="@+id/content_layout"
			android:layout_alignLeft="@+id/content_layout" android:layout_alignBottom="@+id/content_layout"
			android:layout_alignRight="@+id/content_layout"
			android:background="@drawable/preset_btn_rect_transparent_transparent"/>
</RelativeLayout>