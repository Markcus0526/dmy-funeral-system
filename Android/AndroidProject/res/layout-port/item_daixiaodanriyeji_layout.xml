<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR"
				android:id="@+id/parent_layout">

	<LinearLayout
			android:orientation="horizontal"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content">
		<TextView
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:text="代销商"
				android:id="@+id/lbl_item1" android:textColor="#303030"
				android:textSize="22px"
				android:layout_centerVertical="true" android:gravity="center"
				android:background="@drawable/preset_rect_transparent_gray" android:layout_weight="1"
				android:paddingTop="10px" android:paddingBottom="10px"/>
		<TextView
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:text="代销商本月业绩累计"
				android:id="@+id/lbl_item2" android:textColor="#303030"
				android:textSize="22px"
				android:layout_toRightOf="@+id/lbl_item2"
				android:layout_centerVertical="true" android:gravity="center"
				android:background="@drawable/preset_rect_transparent_gray" android:layout_weight="1"
				android:paddingTop="10px" android:paddingBottom="10px"/>
	</LinearLayout>
</RelativeLayout>