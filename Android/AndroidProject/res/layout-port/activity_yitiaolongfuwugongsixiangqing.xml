<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:id="@+id/parent_layout"
				android:background="@color/NORMAL_BACKCOLOR">

	<RelativeLayout android:layout_width="fill_parent" android:layout_height="@dimen/TITLE_HEIGHT"
					android:background="@color/TITLE_BACKCOLOR" android:id="@+id/title_layout">
		<TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="一条龙服务公司详情"
				  android:id="@+id/txt_title" android:textColor="@color/TITLE_FORECOLOR"
				  android:textSize="@dimen/TITLE_FONTSIZE" android:gravity="center"/>
		<ImageButton android:layout_width="@dimen/BACKBUTTON_WIDTH" android:layout_height="match_parent"
					 android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
					 android:src="@drawable/preset_btn_back" android:padding="10px"/>
		<Button android:layout_width="100px" android:layout_height="40px" android:text="预约参观"
				android:id="@+id/btn_reserve_visit" android:layout_alignParentRight="true"
				android:background="@drawable/preset_btn_round_transparent_white" android:layout_centerVertical="true"
				android:layout_marginRight="10px" android:textColor="#FFFFFF" android:textSize="18px"
				android:visibility="invisible"/>
	</RelativeLayout>
	<RelativeLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
					android:id="@+id/content_layout" android:layout_below="@+id/title_layout"
			>
		<ImageView
				android:layout_width="fill_parent"
				android:layout_height="220px"
				android:id="@+id/img_intro" android:background="@drawable/preset_rect_transparent_gray" android:scaleType="centerInside"/>
		<ScrollView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:id="@+id/scroll_content" android:layout_below="@+id/img_intro">
			<RelativeLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_below="@+id/img_intro"
                    android:paddingLeft="20px" android:paddingRight="20px" android:paddingTop="30px"
                    android:paddingBottom="40px">
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="公司名称:"
                        android:id="@+id/lbl_company_name" android:textColor="#404040" android:textSize="22px"/>
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
						android:id="@+id/txt_company_name" android:textSize="22px" android:textColor="#404040"
                        android:layout_toRightOf="@+id/lbl_company_name" android:layout_marginLeft="10px"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="套装价格:"
                          android:id="@+id/lbl_price" android:textColor="#404040" android:textSize="22px"
                          android:layout_alignLeft="@+id/lbl_company_name" android:layout_below="@+id/txt_company_name"
                          android:layout_marginTop="20px"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
						  android:id="@+id/txt_date" android:textSize="22px" android:textColor="#404040"
                          android:layout_alignLeft="@+id/txt_company_name"
                          android:layout_alignTop="@+id/lbl_price"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="公司简介:"
                          android:id="@+id/lbl_company_intro" android:textColor="#404040" android:textSize="22px"
                          android:layout_marginTop="20px" android:layout_below="@+id/txt_date"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
						  android:id="@+id/txt_company_intro" android:textSize="22px" android:textColor="#404040"
                          android:layout_alignLeft="@+id/txt_company_name" android:layout_alignTop="@+id/lbl_company_intro"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="商品介绍:"
                          android:id="@+id/lbl_goods_intro" android:textColor="#404040" android:textSize="22px"
                          android:layout_marginTop="20px" android:layout_below="@+id/txt_company_intro"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
						  android:id="@+id/txt_goods_intro" android:textSize="22px" android:textColor="#404040"
                          android:layout_alignLeft="@+id/txt_company_name"
                          android:layout_alignTop="@+id/lbl_goods_intro"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="服务内容:"
                          android:id="@+id/lbl_service_content" android:textColor="#404040" android:textSize="22px"
                          android:layout_marginTop="20px" android:layout_below="@+id/txt_goods_intro"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
						  android:id="@+id/txt_service_content" android:textSize="22px" android:textColor="#404040"
                          android:layout_alignLeft="@+id/txt_company_name" android:layout_alignTop="@+id/lbl_service_content"/>
            </RelativeLayout>
		</ScrollView>
	</RelativeLayout>
</RelativeLayout>