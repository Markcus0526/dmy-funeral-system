<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="100px"
				android:layout_height="100px" android:background="@color/NORMAL_BACKCOLOR"
				android:id="@+id/parent_layout">

	<ImageView
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:id="@+id/img_main" android:scaleType="centerInside" android:src="@drawable/bk_tomb_kong"
			android:padding="10px"/>
	<ImageButton
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:id="@+id/btn_item" android:background="@drawable/preset_btn_rect_transparent_transparent"/>
</RelativeLayout>