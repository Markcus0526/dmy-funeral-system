<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="fill_parent" android:id="@+id/content_layout">
		<ImageView
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:id="@+id/img_content" android:scaleType="fitXY"
				android:background="@drawable/preset_rect_white_gray"/>
	</RelativeLayout>
	<ImageButton
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:id="@+id/btn_item" android:layout_alignTop="@+id/content_layout"
			android:layout_alignLeft="@+id/content_layout" android:layout_alignBottom="@+id/content_layout"
			android:layout_alignRight="@+id/content_layout"
			android:background="@drawable/preset_btn_rect_transparent_transparent"/>
</RelativeLayout>