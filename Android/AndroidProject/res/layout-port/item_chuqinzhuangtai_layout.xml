<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:padding="10px" android:id="@+id/parent_layout"
				android:background="@color/NORMAL_BACKCOLOR">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content" android:background="@drawable/preset_rect_transparent_gray"
			android:id="@+id/content_layout" android:padding="10px">
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="New Text"
				android:id="@+id/txt_no" android:textColor="#303030" android:textSize="22px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:id="@+id/txt_desc" android:textColor="#303030" android:textSize="22px"
				android:layout_toRightOf="@+id/txt_no"/>
		<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:id="@+id/txt_name" android:textColor="#303030" android:textSize="22px"
				android:layout_alignTop="@+id/txt_desc" android:layout_toRightOf="@+id/txt_desc"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="休假理由："
				android:id="@+id/lbl_reason" android:textColor="#303030" android:textSize="22px"
				android:layout_below="@+id/txt_name" android:layout_marginTop="10px"
				android:layout_alignLeft="@+id/txt_desc"/>
		<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:id="@+id/txt_reason" android:textColor="#303030" android:textSize="22px"
				android:layout_alignTop="@+id/lbl_reason" android:layout_toRightOf="@+id/lbl_reason"/>
	</RelativeLayout>
</RelativeLayout>