<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:id="@+id/parent_layout"
				android:background="@color/NORMAL_BACKCOLOR">

	<RelativeLayout android:layout_width="fill_parent" android:layout_height="@dimen/TITLE_HEIGHT"
					android:background="@color/TITLE_BACKCOLOR" android:id="@+id/title_layout">
		<TextView android:layout_width="match_parent" android:layout_height="match_parent"
				  android:text="代销业绩" android:id="@+id/txt_title" android:textColor="@color/TITLE_FORECOLOR"
				  android:textSize="@dimen/TITLE_FONTSIZE" android:gravity="center"/>
		<ImageButton android:layout_width="@dimen/BACKBUTTON_WIDTH" android:layout_height="match_parent"
					 android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
					 android:src="@drawable/preset_btn_back" android:padding="10px"/>
	</RelativeLayout>
	<RelativeLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
					android:id="@+id/content_layout" android:layout_below="@+id/title_layout">
		<LinearLayout android:orientation="horizontal" android:layout_width="fill_parent"
					  android:layout_height="60px" android:id="@+id/linearLayout3"
					  android:background="@drawable/preset_rect_transparent_gray" android:layout_marginLeft="10px"
					  android:layout_marginRight="10px" android:layout_marginTop="10px">
			<TextView android:layout_width="0dp" android:layout_height="match_parent" android:text="代销商"
					  android:id="@+id/textView38" android:layout_weight="1" android:textColor="#303030"
					  android:textSize="22px" android:paddingTop="10px"
					  android:paddingBottom="10px" android:background="@drawable/preset_rect_transparent_gray"
					  android:gravity="center"/>
			<TextView android:layout_width="0dp" android:layout_height="match_parent" android:text="代销商本月业绩累计"
					  android:id="@+id/textView39" android:layout_weight="1" android:textColor="#303030"
					  android:textSize="22px" android:paddingTop="10px"
					  android:paddingBottom="10px" android:background="@drawable/preset_rect_transparent_gray"
					  android:gravity="center"/>
		</LinearLayout>
		<view android:layout_width="match_parent"
			  android:layout_height="match_parent"
			  class="com.damytech.preset_controls.Android_PullToRefresh.PullToRefreshListView" android:id="@+id/list_view"
			  android:layout_alignLeft="@+id/linearLayout3" android:layout_alignRight="@+id/linearLayout3"
			  android:layout_below="@+id/linearLayout3"/>
	</RelativeLayout>
</RelativeLayout>