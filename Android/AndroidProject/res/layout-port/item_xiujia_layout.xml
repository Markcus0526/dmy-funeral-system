<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR"
				android:id="@+id/parent_content">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content" android:id="@+id/content_layout" android:paddingTop="20px"
			android:paddingBottom="20px" android:paddingLeft="10px" android:paddingRight="10px">
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="休假日期："
				android:id="@+id/lbl_date" android:textColor="#303030" android:textSize="22px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="9999-99-99 99:99:99"
				android:id="@+id/txt_date" android:textColor="#303030" android:textSize="22px"
				android:layout_alignTop="@+id/lbl_date" android:layout_toRightOf="@+id/lbl_date"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="休假理由："
				android:id="@+id/lbl_type" android:textColor="#303030" android:textSize="22px"
				android:layout_below="@+id/txt_date" android:layout_marginTop="14px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:id="@+id/txt_type" android:textColor="#303030" android:textSize="22px"
				android:layout_alignTop="@+id/lbl_type" android:layout_toRightOf="@+id/lbl_type"/>
		<Button
				android:layout_width="130px"
				android:layout_height="50px"
				android:text="取消"
				android:id="@+id/btn_cancel" android:layout_alignParentRight="true"
				android:layout_centerVertical="true" android:background="@drawable/preset_btn_round_green_green"
				android:textColor="#FFFFFF" android:textSize="22px"/>
	</RelativeLayout>
</RelativeLayout>