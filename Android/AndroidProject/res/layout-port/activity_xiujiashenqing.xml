<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:background="@color/NORMAL_BACKCOLOR">
	<RelativeLayout android:layout_width="fill_parent" android:layout_height="@dimen/TITLE_HEIGHT"
					android:background="@color/TITLE_BACKCOLOR" android:id="@+id/title_layout">
		<TextView android:layout_width="match_parent" android:layout_height="match_parent"
				  android:text="休假申请" android:id="@+id/txt_title" android:textColor="@color/TITLE_FORECOLOR"
				  android:textSize="@dimen/TITLE_FONTSIZE" android:gravity="center"/>
		<ImageButton android:layout_width="@dimen/BACKBUTTON_WIDTH" android:layout_height="match_parent"
					 android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
					 android:src="@drawable/preset_btn_back" android:padding="10px"/>
		<ImageButton
				android:layout_width="70px"
				android:layout_height="match_parent"
				android:id="@+id/btn_user" android:layout_alignParentRight="true" android:background="@null"
				android:scaleType="centerInside" android:src="@drawable/preset_btn_user" android:padding="10px"
				android:visibility="invisible"/>
	</RelativeLayout>
	<RelativeLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
					android:id="@+id/content_layout" android:layout_below="@+id/title_layout">
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:id="@+id/txt_date" android:layout_above="@+id/date_layout"
				android:layout_alignLeft="@+id/date_layout" android:layout_alignRight="@+id/date_layout"
				android:gravity="center" android:textColor="#303030" android:textSize="26px"
				/>
		<LinearLayout android:orientation="horizontal" android:layout_width="440px" android:layout_height="wrap_content"
					  android:id="@+id/date_layout" android:layout_centerHorizontal="true"
					  android:layout_above="@+id/txt_reason" android:layout_marginBottom="50px">
			<view class="com.damytech.preset_controls.WheelPicker.WheelView" android:layout_width="0dp"
				  android:layout_height="wrap_content" android:id="@+id/year_view" android:layout_weight="1"/>
			<view class="com.damytech.preset_controls.WheelPicker.WheelView" android:layout_width="0dp"
				  android:layout_height="wrap_content" android:id="@+id/month_view" android:layout_weight="1"/>
			<view class="com.damytech.preset_controls.WheelPicker.WheelView" android:layout_width="0dp"
				  android:layout_height="wrap_content" android:id="@+id/day_view" android:layout_weight="1"/>
		</LinearLayout>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="申请理由"
				android:id="@+id/txt_reason" android:textColor="#303030" android:textSize="24px"
				android:layout_alignLeft="@+id/reason_layout" android:layout_above="@+id/reason_layout"
				android:layout_marginBottom="10px"/>
		<RelativeLayout
				android:layout_width="440px"
				android:layout_height="wrap_content" android:id="@+id/reason_layout"
				android:layout_above="@+id/btn_confirm" android:layout_marginBottom="40px"
				android:layout_centerHorizontal="true" android:padding="10px"
				android:background="@drawable/preset_rect_transparent_gray">
			<RelativeLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" android:id="@+id/selector_layout"
					android:layout_centerHorizontal="true">
				<ImageView
						android:layout_width="50px"
						android:layout_height="50px"
						android:id="@+id/img_normal" android:scaleType="centerInside"
						android:src="@drawable/bk_radio_sel"
						/>
				<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="列休"
						android:id="@+id/txt_normal" android:textColor="#303030" android:textSize="24px"
						android:gravity="center" android:layout_alignTop="@+id/img_normal"
						android:layout_alignBottom="@+id/img_normal" android:layout_toRightOf="@+id/img_normal"
						/>
				<ImageButton
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:id="@+id/btn_normal" android:layout_alignTop="@+id/img_normal"
						android:layout_alignLeft="@+id/img_normal" android:layout_alignBottom="@+id/img_normal"
						android:layout_alignRight="@+id/txt_normal" android:background="@null"/>
				<ImageView android:layout_width="50px" android:layout_height="50px"
						   android:id="@+id/img_illness" android:scaleType="centerInside"
						   android:src="@drawable/bk_radio_normal" android:layout_toRightOf="@+id/txt_normal"
						   android:layout_alignTop="@+id/txt_normal" android:layout_marginLeft="40px"/>
				<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="病休"
						  android:id="@+id/txt_illness" android:textColor="#303030" android:textSize="24px"
						  android:gravity="center" android:layout_alignTop="@+id/img_illness"
						  android:layout_toRightOf="@+id/img_illness" android:layout_alignBottom="@+id/img_illness"
						/>
				<ImageButton android:layout_width="wrap_content" android:layout_height="wrap_content"
							 android:id="@+id/btn_illness" android:layout_alignBottom="@+id/img_illness"
							 android:layout_alignTop="@+id/img_illness" android:layout_alignLeft="@+id/img_illness"
							 android:layout_alignRight="@+id/txt_illness" android:background="@null"/>
				<ImageView android:layout_width="50px" android:layout_height="50px"
						   android:id="@+id/img_others" android:scaleType="centerInside"
						   android:src="@drawable/bk_radio_normal" android:layout_alignTop="@+id/txt_illness"
						   android:layout_toRightOf="@+id/txt_illness" android:layout_marginLeft="40px"/>
				<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="其他"
						  android:id="@+id/txt_others" android:textColor="#303030" android:textSize="24px"
						  android:gravity="center" android:layout_alignTop="@+id/img_others"
						  android:layout_toRightOf="@+id/img_others" android:layout_alignBottom="@+id/img_others"
						/>
				<ImageButton android:layout_width="wrap_content" android:layout_height="wrap_content"
							 android:id="@+id/btn_others" android:layout_alignTop="@+id/img_others"
							 android:layout_alignLeft="@+id/img_others" android:layout_alignBottom="@+id/img_others"
							 android:layout_alignRight="@+id/txt_others" android:background="@null"/>
			</RelativeLayout>
		</RelativeLayout>
		<Button
				android:layout_width="400px"
				android:layout_height="54px"
				android:text="提交申请"
				android:id="@+id/btn_confirm" android:layout_alignParentBottom="true"
				android:layout_marginBottom="30px" android:layout_centerHorizontal="true"
				android:background="@drawable/preset_btn_round_green_green" android:textColor="#FFFFFF"
				android:textSize="22px"/>
	</RelativeLayout>
</RelativeLayout>