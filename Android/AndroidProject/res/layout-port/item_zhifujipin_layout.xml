<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:id="@+id/parent_layout"
				android:background="@color/NORMAL_BACKCOLOR">

	<RelativeLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content" android:id="@+id/content_layout"
			android:background="@drawable/preset_rect_transparent_gray" android:padding="10px">
		<ImageView
				android:layout_width="100px"
				android:layout_height="100px"
				android:id="@+id/img_product" android:background="@drawable/preset_rect_transparent_gray"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="类型："
				android:id="@+id/lbl_type" android:textColor="#303030" android:textSize="20px"
				android:layout_toRightOf="@+id/img_product" android:layout_marginLeft="20px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="New Text"
				android:id="@+id/txt_type" android:textColor="#303030" android:textSize="20px"
				android:layout_toRightOf="@+id/lbl_type" android:layout_alignTop="@+id/lbl_type"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="New Text"
				android:id="@+id/txt_name" android:textColor="#009944" android:textSize="20px"
				android:layout_below="@+id/txt_type"
				android:layout_alignLeft="@+id/lbl_type" android:layout_marginTop="8px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="价格："
				android:id="@+id/lbl_price" android:textColor="#303030" android:textSize="20px"
				android:gravity="center"
				android:layout_alignTop="@+id/txt_date"
				android:layout_alignBottom="@+id/txt_date" android:layout_alignLeft="@+id/txt_name"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="New Text"
				android:id="@+id/txt_date" android:textColor="#FF0000" android:textSize="30px"
				android:layout_alignParentRight="false"
				android:layout_toRightOf="@+id/lbl_price" android:layout_below="@+id/txt_name"
				android:layout_marginTop="4px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="数量："
				android:id="@+id/lbl_count" android:textColor="#303030" android:textSize="20px"
				android:layout_toRightOf="@+id/txt_name" android:layout_alignTop="@+id/txt_name"
				android:layout_marginLeft="20px"/>
		<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="New Text"
				android:id="@+id/txt_count" android:textColor="#303030" android:textSize="20px"
				android:layout_alignTop="@+id/lbl_count" android:layout_toRightOf="@+id/lbl_count"/>
	</RelativeLayout>
</RelativeLayout>