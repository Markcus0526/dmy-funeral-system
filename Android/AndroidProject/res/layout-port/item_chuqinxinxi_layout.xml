<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:background="@color/NORMAL_BACKCOLOR"
				android:id="@+id/parent_layout" android:paddingLeft="10px" android:paddingRight="10px">

	<LinearLayout
			android:orientation="horizontal"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content" android:id="@+id/content_layout"
			android:background="@drawable/preset_rect_white_gray">
		<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="名称"
				android:id="@+id/txt_name" android:gravity="center" android:layout_weight="2"
				android:textColor="#303030" android:textSize="20px" android:paddingTop="10px"
				android:paddingBottom="10px" android:background="@drawable/preset_rect_transparent_gray"/>
		<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="职位"
				android:id="@+id/txt_desc" android:gravity="center" android:layout_weight="2"
				android:textColor="#303030" android:textSize="20px" android:paddingTop="10px"
				android:paddingBottom="10px" android:background="@drawable/preset_rect_transparent_gray"/>
		<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="当月"
				android:id="@+id/txt_month" android:gravity="center" android:layout_weight="1"
				android:textColor="#303030" android:textSize="20px" android:paddingTop="10px"
				android:paddingBottom="10px" android:background="@drawable/preset_rect_transparent_gray"/>
		<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="年度"
				android:id="@+id/txt_year" android:gravity="center" android:layout_weight="1"
				android:textColor="#303030" android:textSize="20px" android:paddingTop="10px"
				android:paddingBottom="10px" android:background="@drawable/preset_rect_transparent_gray"/>
	</LinearLayout>
</RelativeLayout>